#!/usr/bin/make -f
include /usr/share/dpkg/architecture.mk

export DEB_CFLAGS_APPEND = -Wno-error=date-time

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure -- \
		-Dtests=false \
		-Ddocs=disabled \
		-Dim_hangul=enabled \
		-Dlibtsm:default_library=static \
		--force-fallback-for=libtsm

override_dh_auto_install:
	dh_auto_install
	rm -f debian/kmscon-hangul/usr/lib/$(DEB_HOST_MULTIARCH)/libtsm.so*
	rm -f debian/kmscon-hangul/usr/include/libtsm.h
	rm -f debian/kmscon-hangul/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/libtsm.pc
